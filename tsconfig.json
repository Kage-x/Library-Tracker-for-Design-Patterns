{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./Frontend",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "declaration": false
  },
  "include": [ "Frontend/**/*.ts" ],
  "exclude": [ "backend", "node_modules", "dist" ]
}